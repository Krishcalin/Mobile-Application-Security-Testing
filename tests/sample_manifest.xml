<?xml version="1.0" encoding="utf-8"?>
<!-- Intentionally vulnerable AndroidManifest.xml for testing MAST scanner v2.0 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.vulnerable"
    android:versionCode="1"
    android:versionName="1.0">

    <uses-sdk
        android:minSdkVersion="19"
        android:targetSdkVersion="33" />

    <!-- Dangerous permissions (MAST-MANIFEST-009) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- MAST-MANIFEST-010: Overlay permission -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- MAST-PRIV-004: Background location tracking -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:usesCleartextTraffic="true"
        android:label="VulnerableApp"
        android:icon="@mipmap/ic_launcher"
        android:taskAffinity="com.example.other">

        <!-- Exported activity without permission (launcher — skipped by scanner) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MAST-MANIFEST-003: Exported activity with deep link -->
        <activity
            android:name=".DeepLinkActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="vulnapp" android:host="open" />
            </intent-filter>
        </activity>

        <!-- MAST-MANIFEST-004: Exported service without permission -->
        <service
            android:name=".BackgroundService"
            android:exported="true" />

        <!-- MAST-MANIFEST-005: Exported broadcast receiver -->
        <receiver
            android:name=".DataReceiver"
            android:exported="true" />

        <!-- MAST-MANIFEST-006: Exported content provider without permissions -->
        <provider
            android:name=".UserDataProvider"
            android:authorities="com.example.vulnerable.provider"
            android:exported="true" />
    </application>
</manifest>
